---
# KORAL Kubernetes Secret Template
# Usage:
#   1. Copy this file: cp koral-secrets.yaml.template koral-secrets.yaml
#   2. Replace all <base64-encoded-...> values with:
#      echo -n "your-value" | base64
#   3. Apply: kubectl apply -f koral-secrets.yaml -n koral-system
#   4. NEVER commit koral-secrets.yaml to git
#
# For production, prefer Sealed Secrets:
#   kubeseal --format yaml < koral-secrets.yaml > koral-sealed-secrets.yaml

apiVersion: v1
kind: Secret
metadata:
  name: koral-secrets
  namespace: koral-system
type: Opaque
data:
  # Auth
  API_KEY: <base64-encoded-api-key>
  API_KEY_ADMIN: <base64-encoded-admin-api-key>
  API_KEY_OPERATOR: <base64-encoded-operator-api-key>
  API_KEY_VIEWER: <base64-encoded-viewer-api-key>
  JWT_SECRET: <base64-encoded-jwt-secret>

  # Database
  POSTGRES_USER: <base64-encoded-db-user>
  POSTGRES_PASSWORD: <base64-encoded-db-password>
  DATABASE_URL: <base64-encoded-database-url>

  # AI
  OPENAI_API_KEY: <base64-encoded-openai-key>
  ANTHROPIC_API_KEY: <base64-encoded-anthropic-key>

  # Email / Alerting
  SMTP_USER: <base64-encoded-smtp-user>
  SMTP_PASS: <base64-encoded-smtp-pass>
  ALERT_EMAIL: <base64-encoded-alert-email>
  SLACK_WEBHOOK_URL: <base64-encoded-slack-webhook>
  TELEGRAM_BOT_TOKEN: <base64-encoded-telegram-token>
  TELEGRAM_CHAT_ID: <base64-encoded-telegram-chat-id>

  # Grafana
  GRAFANA_ADMIN_PASSWORD: <base64-encoded-grafana-password>
