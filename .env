# ─────────────────────────────────────────────────────────────────
#  KORAL Production Environment Configuration
# ─────────────────────────────────────────────────────────────────

# ── AI API Keys (at least one required for AI explanations) ──────
# OpenAI API Key (supports both direct OpenAI and OpenRouter)
OPENAI_API_KEY=

# Anthropic Claude API Key (optional fallback)
ANTHROPIC_API_KEY=

# ── Prometheus Configuration ─────────────────────────────────────
PROMETHEUS_URL=http://monitoring-kube-prometheus-prometheus.koral-system:9090

# ── Kubernetes Namespace to Monitor ─────────────────────────────
KORAL_NAMESPACE=koral-system

# ── Anomaly Detection Configuration ─────────────────────────────
# Z-score threshold (2.5 = moderate sensitivity, 3.0 = less sensitive)
Z_THRESHOLD=2.5

# Agent polling interval in seconds
POLL_INTERVAL=10

# ── Developer Alert Configuration ───────────────────────────────
# Email for critical incident alerts
ALERT_EMAIL=mohammedayan262005@gmail.com

# Gmail SMTP Configuration (for email alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Slack webhook URL (optional)
ALERT_WEBHOOK_URL=

# ── Service URLs (for Docker/K8s) ───────────────────────────────
BACKEND_URL=http://backend:8000
CORRELATION_ENGINE_URL=http://correlation-engine:8005
AI_ENGINE_URL=http://ai-engine:8006

# ── Frontend Configuration ──────────────────────────────────────
FRONTEND_PORT=3000

# ── Database Path ───────────────────────────────────────────────
DB_PATH=/data/koral.db
