# ─────────────────────────────────────────────────────────────────
#  KORAL Environment Configuration
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ── AI API Keys (at least one required for AI explanations) ──────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Your Prometheus server ───────────────────────────────────────
# Point this at your real Prometheus instance
# Example: http://192.168.1.100:9090
# Leave as default if running Prometheus in Docker on same machine
PROMETHEUS_URL=http://prometheus:9090

# ── Your Kubernetes namespace to monitor ────────────────────────
KORAL_NAMESPACE=default

# ── Anomaly detection sensitivity ───────────────────────────────
# Higher = less sensitive (fewer alerts)
# Lower  = more sensitive (more alerts)
Z_THRESHOLD=2.5

# How often agents poll Prometheus (seconds)
POLL_INTERVAL=10

# ── Developer Alerts ─────────────────────────────────────────────
# Slack webhook URL for critical incident alerts
# Get from: https://api.slack.com/messaging/webhooks
ALERT_WEBHOOK_URL=

# Email for critical alerts (optional)
ALERT_EMAIL= mohammedayan262005@gmail.com

# ── Frontend port ────────────────────────────────────────────────
FRONTEND_PORT=3000

# ── Fluentd (for log agent) ──────────────────────────────────────
FLUENTD_HOST=fluentd
FLUENTD_PORT=9880
