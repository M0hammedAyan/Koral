# ─────────────────────────────────────────────────────────────────────────────
# KORAL Environment Variables
# Copy this file to .env and fill in your values before starting the stack.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Use "sqlite" for local development, "postgres" for production.
# When DB_TYPE=sqlite the backend writes to a local file; all other DB_* vars
# are ignored. When DB_TYPE=postgres the stack connects via PgBouncer.
DB_TYPE=sqlite
DB_HOST=pgbouncer
DB_PORT=6432
DB_NAME=koral
DB_USER=koral
# Strong random password for the PostgreSQL koral user.
DB_PASS=
# Full DSN used by Alembic migrations and direct psycopg2 connections.
# Format: postgresql://<DB_USER>:<DB_PASS>@<DB_HOST>:<DB_PORT>/<DB_NAME>
DATABASE_URL=

# ── Authentication ────────────────────────────────────────────────────────────
# Master API key used by services that have not yet been migrated to role keys.
# Must be a long random string (min 32 chars recommended).
API_KEY=
# Role-scoped keys — each grants a different permission level.
# ADMIN: full access including audit log and destructive ops.
# OPERATOR: can post anomalies, create remediation plans, run approvals.
# VIEWER: read-only access to all GET endpoints.
# If the role keys are unset, API_KEY is accepted at OPERATOR level.
API_KEY_ADMIN=
API_KEY_OPERATOR=
API_KEY_VIEWER=
# Secret used to sign and verify JWT tokens (if JWT auth is used).
# Must be a long random string; rotate immediately if exposed.
JWT_SECRET=
# Comma-separated list of allowed CORS origins for the frontend.
ALLOWED_ORIGINS=http://localhost:3000
# Set to "true" to bypass all auth checks — for local dev only, never in prod.
DISABLE_AUTH=false

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# API key for OpenAI (used by ai-engine for GPT-4o fix recommendations).
OPENAI_API_KEY=
# API key for Anthropic Claude (alternative LLM backend).
ANTHROPIC_API_KEY=

# ── Email & Alerting ─────────────────────────────────────────────────────────
# Address that receives operational alerts and approval request emails.
ALERT_EMAIL=
# SMTP server hostname and port for outbound email.
SMTP_HOST=
SMTP_PORT=587
# SMTP login credentials — use an app-specific password, not your main password.
SMTP_USER=
SMTP_PASS=
# Optional webhook URL for alert forwarding (Slack incoming webhook, etc.).
ALERT_WEBHOOK_URL=

# ── Container Registry ──────────────────────────────────────────────────────
# Used by the CI/CD pipeline to push built images. Set these as GitHub Actions
# secrets rather than in .env — they are listed here for documentation only.
DOCKER_USERNAME=
DOCKER_PASSWORD=

# ── Service URLs ─────────────────────────────────────────────────────────────
# Internal addresses used by the backend to reach other KORAL services.
# These default to the Docker Compose service names and rarely need changing.
KORAL_NAMESPACE=koral-system
BACKEND_URL=http://backend:8000
CORRELATION_ENGINE_URL=http://correlation-engine:8005
AI_ENGINE_URL=http://ai-engine:8006
PROMETHEUS_URL=http://prometheus:9090
# Redis connection string for the distributed rate limiter.
# Leave empty to fall back to in-process rate limiting.
REDIS_URL=redis://redis:6379/0

# ── Observability Tuning ─────────────────────────────────────────────────────
# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Z-score threshold above which a metric reading is flagged as an anomaly.
Z_THRESHOLD=2.5
# How often (in seconds) the agents poll Kubernetes / Prometheus for metrics.
POLL_INTERVAL=10

# ── Local Development ─────────────────────────────────────────────────────────
# Host port the React frontend dev server is mapped to.
FRONTEND_PORT=3000
# Fluentd log shipping endpoint (optional — only needed if using log-agent).
FLUENTD_HOST=fluentd
FLUENTD_PORT=9880
