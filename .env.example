# ═══════════════════════════════════════════════════════════════════════════
# KORAL Production Environment Variables
# Copy this to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════

# DATABASE CONFIGURATION
# Use 'sqlite' for development (default), 'postgres' for production
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=koral
DB_USER=koral
DB_PASS=your-secure-postgres-password-here

# AUTHENTICATION & SECURITY
API_KEY=your-secure-api-key-here
JWT_SECRET=your-jwt-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000
DISABLE_AUTH=false

# AI & LLM
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# EMAIL & ALERTING
ALERT_EMAIL=ops-team@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail-or-smtp-user@example.com
SMTP_PASS=your-16-char-app-password-here
ALERT_WEBHOOK_URL=

# CONTAINER REGISTRY
# Create matching GitHub repository secrets for workflow access
DOCKER_USERNAME=your-docker-username
DOCKER_PASSWORD=your-docker-password-or-access-token

# KUBERNETES & SERVICES
KORAL_NAMESPACE=koral-system
BACKEND_URL=http://backend:8000
CORRELATION_ENGINE_URL=http://correlation-engine:8005
AI_ENGINE_URL=http://ai-engine:8006
PROMETHEUS_URL=http://prometheus:9090

# MONITORING
LOG_LEVEL=INFO
Z_THRESHOLD=2.5
POLL_INTERVAL=10

# LOCAL DEVELOPMENT
FRONTEND_PORT=3000
FLUENTD_HOST=fluentd
FLUENTD_PORT=9880
