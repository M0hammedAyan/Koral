HONEYCOMB_DATASET=koral-production

# Feature Flags
FEATURE_AI_ANALYSIS=true
FEATURE_EMAIL_ALERTS=true
FEATURE_SLACK_INTEGRATION=true
FEATURE_PAGERDUTY_INTEGRATION=false

# Security
CORS_ALLOWED_ORIGINS=https://koral.ai,https://api.koral.ai
DISABLE_AUTH=false

# Performance Tuning
DB_POOL_MIN=5
DB_POOL_MAX=20
CACHE_TTL=3600
REQUEST_TIMEOUT=30

# Deployment
ENVIRONMENT=production
KORAL_NAMESPACE=koral-system
LOG_LEVEL=INFO
DEBUG_MODE=false

# Backup and Recovery
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_VERIFY=true

# Security Headers
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Health Checks
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_RETRIES=3

# Notes for secure secret management:
# 1. Never commit this file with real values to git
# 2. Use Kubernetes Secrets for runtime values
# 3. Use HashiCorp Vault or AWS Secrets Manager for secret rotation
# 4. Enable audit logging for all secret access
# 5. Use strong passwords (minimum 32 characters for critical secrets)
# 6. Rotate secrets quarterly or when compromised
# 7. Use separate secrets per environment (dev/staging/production)
# 8. Document secret ownership and access policies
